{
  "expo": {
    "name": "Smart Tap",
    "slug": "smarttap-nfc-writer",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/branding/app_icon.png",
    "scheme": "smarttap-nfc",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.com.smarttap.nfcwriter",
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "TAG"
        ]
      },
      "infoPlist": {
        "NFCReaderUsageDescription": "This app uses NFC to write your profile URL to SmartTap business cards.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "au.com.smarttap.nfcwriter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/app_icon.png",
        "backgroundColor": "#121212"
      },
      "permissions": [
        "NFC",
        "android.permission.NFC"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/logo_dark.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#121212"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Allow SmartTap to interact with nearby NFC devices.",
          "includeNdefEntitlement": false
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ce38391-7150-467c-aefd-cd46c303e7fb"
      }
    },
    "owner": "wppro"
  }
}
